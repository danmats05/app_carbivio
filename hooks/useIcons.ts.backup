 * import { useIcons } from "@/hooks/useIcons";
 * 
 * function MyComponent() {
 *   const { icons } = useIcons();
 *   
 *   return (
 *     <div>
 *       <icons.Truck className="w-5 h-5" />
 *       <icons.TrendUp className="w-4 h-4 text-green-500" />
