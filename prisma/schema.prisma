generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum VehicleStatus {
  EN_ROUTE
  DISPONIBLE
  MAINTENANCE
  HORS_SERVICE
}

model User {
  id              String           @id @default(uuid())
  name            String
  email           String           @unique
  password        String
  role            Role             @default(USER)
  createdAt       DateTime         @default(now()) @map("created_at")
  serviceRequests ServiceRequest[]

  @@map("users")
}

model ServiceRequest {
  id          String        @id @default(uuid())
  userId      String        @map("user_id")
  serviceType String        @map("service_type")
  description String        @db.Text
  location    String
  latitude    Float?        @map("latitude")
  longitude   Float?        @map("longitude")
  status      RequestStatus @default(APPROVED)
  price       Float?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("service_requests")
}

model AdminLog {
  id        String   @id @default(uuid())
  adminId   String   @map("admin_id")
  action    String
  targetId  String?  @map("target_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admin_logs")
}

model Vehicle {
  id                String        @id @default(uuid())
  plaque            String        @unique
  modele            String
  chauffeur         String
  statut            VehicleStatus  @default(DISPONIBLE) @map("statut")
  localisation       String
  carburant         Int           @default(100)
  dernierEntretien  DateTime?     @map("dernier_entretien")
  prochainEntretien DateTime?     @map("prochain_entretien")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  @@map("vehicles")
}

enum StockCategory {
  FUEL
  BATTERY
  OIL
  TIRE
}

enum StockStatus {
  AVAILABLE
  LOW
  CRITICAL
}

model StockItem {
  id            String         @id @default(uuid())
  name          String
  category      StockCategory
  quantity      Int
  unit          String
  unitPrice     Int            @map("unit_price")
  totalValue    Int            @map("total_value")
  supplier      String
  receivedDate  DateTime       @map("received_date")
  location      String
  status        StockStatus    @default(AVAILABLE)
  lastUpdated   DateTime       @default(now()) @map("last_updated")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@map("stock_items")
}
